# WordPress REST API 認証用（test_get_urls.py 等）
# このファイルを .env にコピーし、実際の値を設定してください。
# cp .env.example .env

# WordPress サイトのURL（末尾のスラッシュなし）
WP_SITE_URL=https://example.com

# WordPress ユーザー名（管理者）
WP_USER=admin

# Application Password（WordPress 管理画面で発行）
# ユーザー > プロフィール > アプリケーションパスワード
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
